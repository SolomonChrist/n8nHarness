    },
    {
      "parameters": {
        "jsCode": "const memoryUpdate = ($json.memory_update || '').trim();\nconst runTime = $json.run_time || new Date().toISOString();\n\nif (!memoryUpdate) {\n  return [{\n    json: {\n      memory_insert_text: ''\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    memory_insert_text: `\\n- ${runTime}: ${memoryUpdate}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3968,
        -608
      ],
      "id": "0a48dc7c-0f45-4429-b703-9ea2bc88e5e6",
      "name": "Prep Memory Update"
    },
    {
      "parameters": {
        "jsCode": "const oldTasks = $('TASKS').item.json.content || '';\nconst taskAction = ($json.task_action || 'none').trim();\nconst taskPayload = ($json.task_payload || '').trim();\nconst nextTask = ($json.next_task || '').trim();\nconst runTime = $json.run_time || new Date().toISOString();\n\nconst blocked = [\n  'stay idle until next heartbeat trigger',\n  'check for next user input',\n  'check for the next user input or stay idle if nothing new exists',\n  'wait for next trigger',\n  'idle'\n];\n\nfunction normalizeTaskText(task) {\n  return task\n    .replace(/^- \\[ \\]\\s*/, '')\n    .replace(/\\s*\\|\\s*\\d{4}-\\d{2}-\\d{2}T.*$/, '')\n    .trim();\n}\n\nconst existingLines = oldTasks\n  .split('\\n')\n  .map(line => line.trim())\n  .filter(Boolean);\n\nlet lineToInsert = '';\n\n// NORMAL TASK\nif (taskAction === 'add_task') {\n\n  let cleanTask = taskPayload\n    ? normalizeTaskText(taskPayload)\n    : normalizeTaskText(nextTask);\n\n  if (\n    cleanTask &&\n    !blocked.includes(cleanTask.toLowerCase())\n  ) {\n    const existingTasks = existingLines\n      .filter(line => line.startsWith('- [ ]'))\n      .map(line => normalizeTaskText(line).toLowerCase());\n\n    if (!existingTasks.includes(cleanTask.toLowerCase())) {\n      lineToInsert = `\\n- [ ] ${cleanTask} | ${runTime}`;\n    }\n  }\n}\n\n// REMINDER\nif (taskAction === 'add_reminder') {\n  if (taskPayload && !existingLines.includes(taskPayload)) {\n    lineToInsert = `\\n${taskPayload}`;\n  }\n}\n\n// REMOVE REMINDER\nif (taskAction === 'remove_reminder') {\n  lineToInsert = '';\n}\n\n// FALLBACK (older prompt behavior)\nif (!lineToInsert && taskAction === 'none' && nextTask) {\n\n  const cleanTask = normalizeTaskText(nextTask);\n\n  if (\n    cleanTask &&\n    !blocked.includes(cleanTask.toLowerCase())\n  ) {\n    lineToInsert = `\\n- [ ] ${cleanTask} | ${runTime}`;\n  }\n}\n\nreturn [{\n  json: {\n    task_insert_text: lineToInsert\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
