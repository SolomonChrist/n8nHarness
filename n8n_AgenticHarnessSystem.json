    {
      "parameters": {
        "jsCode": "let raw =\n  $json.output ??\n  $json.text ??\n  $json.response ??\n  $json.content ??\n  JSON.stringify($json);\n\nif (typeof raw !== 'string') {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw.trim();\n\nfunction normalize(parsed) {\n  return {\n    reply_needed: !!parsed.reply_needed,\n    reply_message: parsed.reply_message || 'IDLE',\n    next_task: parsed.next_task || '',\n    memory_update: parsed.memory_update || '',\n    task_action: parsed.task_action || 'none',\n    task_payload: parsed.task_payload || '',\n    raw_agent_output: raw\n  };\n}\n\ntry {\n  const parsed = JSON.parse(raw);\n  return [{ json: normalize(parsed) }];\n} catch (e) {}\n\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nif (match) {\n  try {\n    const parsed = JSON.parse(match[0]);\n    return [{ json: normalize(parsed) }];\n  } catch (e) {}\n}\n\nreturn [{\n  json: {\n    reply_needed: false,\n    reply_message: 'IDLE',\n    next_task: '',\n    memory_update: '',\n    task_action: 'none',\n    task_payload: '',\n    raw_agent_output: raw,\n    parse_error: true\n  }\n}];"
      },
